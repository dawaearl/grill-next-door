# =============================================================================
# Grill next Door — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials before running server.js
# NEVER commit the real .env file to version control.

# Your Gmail address (the account that sends confirmation emails)
GMAIL_USER=your.email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
# Select "Mail" and your device → Google will give you a 16-character password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Port for the backend server (default: 3000)
PORT=3000

# Base URL used to build QR code links (update to your public URL if deployed)
# For local testing: http://localhost:8000
BASE_URL=http://localhost:8000
